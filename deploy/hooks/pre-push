#!/bin/sh
# Makapix pre-push hook — enforce the API contract before pushing.
#
# Install with:  make install-hooks
#
# Runs the FAST contract gate (`make check`: OpenAPI drift + formatting) so
# pushes stay quick. The full test suite is intentionally not gated here — run
# `make check-full` before merging to main / deploying to prod.
#
# Requires the dev stack to be running (it execs into the api container), since
# this repo has no cloud CI. Set SKIP_MAKE_CHECK=1 to bypass in a pinch.
set -e

if [ "$SKIP_MAKE_CHECK" = "1" ]; then
    echo "[pre-push] SKIP_MAKE_CHECK=1 set — skipping 'make check'."
    exit 0
fi

echo "[pre-push] running 'make check' (OpenAPI drift + format; fast gate)..."
echo "[pre-push] note: full test suite not gated here — run 'make check-full' before merge/deploy."
make check
